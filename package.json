{
  "name": "emby-tok",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:bench": "vitest bench",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "test:performance": "playwright test --grep performance",
    "benchmark:save": "node scripts/benchmark-compare.js save-baseline",
    "benchmark:compare": "node scripts/benchmark-compare.js compare",
    "cap:add": "cap add android",
    "cap:sync": "cap sync",
    "build:android": "tsc && vite build && cap sync android",
    "version:current": "node scripts/version-manager.js current",
    "version:patch": "node scripts/version-manager.js bump patch",
    "version:minor": "node scripts/version-manager.js bump minor",
    "version:major": "node scripts/version-manager.js bump major",
    "version:set": "node scripts/version-manager.js set",
    "changelog:generate": "node scripts/extract-changelog.js",
    "release:check": "node scripts/pre-release-check.js",
    "build:app": "node scripts/build.js",
    "build:app:debug": "node scripts/build.js --debug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.0.0",
    "framer-motion": "^12.36.0",
    "glob": "^13.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "autoprefixer": "^10.4.18",
    "happy-dom": "^13.3.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.2",
    "vitest": "^1.2.0"
  }
}
